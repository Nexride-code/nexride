rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isImageUpload() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }

    match /ride_chats/{rideId}/{senderUid}/{fileName} {
      allow write: if isSignedIn() && request.auth.uid == senderUid && isImageUpload();
      allow read: if isSignedIn();
    }

    match /ride_payment_proofs/{rideId}/{uid}/{fileName} {
      allow write: if isSignedIn() && request.auth.uid == uid && isImageUpload();
      allow read: if isSignedIn();
    }

    match /dispatch_uploads/{rideId}/{category}/{fileName} {
      allow write: if isSignedIn() && isImageUpload();
      allow read: if isSignedIn();
    }

    match /driver_documents/{uid}/{fileName} {
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && isImageUpload();
      allow read: if isSignedIn();
    }

    // Bank transfer receipts: rider uploads under their uid; admin may read via token URL or client with admin claim.
    match /receipts/{uid}/{rideId}/{fileName} {
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && fileName == 'bank_transfer_receipt.jpg'
        && isImageUpload();
      allow read: if isSignedIn()
        && (request.auth.uid == uid || request.auth.token.admin == true);
    }
  }
}
