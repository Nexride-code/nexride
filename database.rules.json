{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "payment_methods": {
          "$methodId": {
            ".validate": "!newData.hasChild('cvv') && !newData.hasChild('pan') && !newData.hasChild('card_number') && !newData.hasChild('cardNumber') && !newData.hasChild('number') && !newData.hasChild('cardPan') && (!newData.hasChild('last4') || (newData.child('last4').isString() && newData.child('last4').val().matches(/^\\d{3,4}$/)))"
          }
        },
        "kyc_status": {
          ".validate": "!newData.hasChildren() || ((!newData.hasChild('nin_verified') || newData.child('nin_verified').isBoolean()) && (!newData.hasChild('bvn_verified') || newData.child('bvn_verified').isBoolean()) && (!newData.hasChild('face_matched') || newData.child('face_matched').isBoolean()) && (!newData.hasChild('kyc_approved') || newData.child('kyc_approved').isBoolean()) && (!newData.hasChild('kyc_admin_override') || newData.child('kyc_admin_override').isBoolean()))"
        }
      }
    },
    "riders": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "Users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "drivers": {
      ".indexOn": ["dispatch_market", "market_pool", "market", "city"],
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "driver_presence": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "online_drivers": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "active_driver_locations": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "dispatch": {
      "$market": {
        ".read": "auth != null",
        ".write": false
      }
    },
    "ride_dispatch": {
      "$rideId": {
        ".read": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))",
        ".write": false
      }
    },

    "driver_offer_queue": {
      "$driverId": {
        ".read": "auth != null && auth.uid === $driverId",
        ".write": false,
        "$rideId": {
          ".read": "auth != null && auth.uid === $driverId",
          ".write": false
        }
      }
    },
    "driver_offer_queue_debug": {
      "$driverId": {
        ".read": "auth != null && auth.uid === $driverId",
        ".write": false,
        "$rideId": {
          ".read": "auth != null && auth.uid === $driverId",
          ".write": false
        }
      }
    },
    "delivery_offer_queue": {
      "$driverId": {
        ".read": "auth != null && auth.uid === $driverId",
        ".write": false,
        "$deliveryId": {
          ".read": "auth != null && auth.uid === $driverId",
          ".write": false
        }
      }
    },
    "delivery_offer_fanout": {
      "$deliveryId": {
        ".read": false,
        ".write": false
      }
    },
    "ride_offer_fanout": {
      "$rideId": {
        ".read": false,
        ".write": false
      }
    },

    "rider_verifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "driver_verifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "rider_device_fingerprints": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "driver_device_fingerprints": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "app_config": {
      "rider_trust_rules": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users/' + auth.uid + '/role').val() === 'admin'"
      },
      "nexride_dispatch": {
        ".read": false,
        ".write": false
      },
      "nexride_rider": {
        ".read": false,
        ".write": false
      }
    },

    "rider_risk_flags": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "rider_payment_flags": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "rider_reputation": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "payment_methods": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$methodId": {
          ".validate": "!newData.hasChild('cvv') && !newData.hasChild('pan') && !newData.hasChild('card_number') && !newData.hasChild('cardNumber') && !newData.hasChild('number') && !newData.hasChild('cardPan')"
        }
      }
    },

    "payment_transactions": {
      "$txRef": {
        ".read": "auth != null && (data.child('rider_id').val() === auth.uid || data.child('driver_id').val() === auth.uid)",
        ".write": false
      }
    },
    "webhook_applied": {
      ".read": false,
      ".write": false
    },
    "flutterwave_charges": {
      ".read": false,
      ".write": false
    },

    "driver_active_rides": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "rider_active_rides": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "rider_active_trip": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "user_active_delivery": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },
    "driver_active_delivery": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },

    "ride_requests": {
      ".indexOn": [
        "rider_id",
        "driver_id",
        "matched_driver_id",
        "status",
        "trip_state",
        "updated_at"
      ],
      ".read": "auth != null && ((query.orderByChild == 'rider_id' && query.equalTo == auth.uid) || (query.orderByChild == 'driver_id' && query.equalTo == auth.uid) || (query.orderByChild == 'matched_driver_id' && query.equalTo == auth.uid))",
      "$rideId": {
        ".read": "auth != null && ((data.child('rider_id').val() === auth.uid) || (data.child('riderId').val() === auth.uid) || (data.child('driver_id').val() === auth.uid) || (data.child('driverId').val() === auth.uid) || (data.child('matched_driver_id').val() === auth.uid) || (data.child('matchedDriverId').val() === auth.uid))",
        ".write": false
      }
    },

    "delivery_requests": {
      ".indexOn": [
        "customer_id",
        "driver_id",
        "matched_driver_id",
        "status",
        "trip_state",
        "updated_at"
      ],
      ".read": "auth != null && ((query.orderByChild == 'customer_id' && query.equalTo == auth.uid) || (query.orderByChild == 'driver_id' && query.equalTo == auth.uid) || (query.orderByChild == 'matched_driver_id' && query.equalTo == auth.uid))",
      "$deliveryId": {
        ".read": "auth != null && ((data.child('customer_id').val() === auth.uid) || (data.child('rider_id').val() === auth.uid) || (data.child('driver_id').val() === auth.uid) || (data.child('matched_driver_id').val() === auth.uid))",
        ".write": false
      }
    },

    "active_rides": {
      "$rideId": {
        ".read": "auth != null && ((data.child('rider_id').val() === auth.uid) || (data.child('driver_id').val() === auth.uid) || (data.child('matched_driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))",
        ".write": false
      }
    },
    "active_trips": {
      "$rideId": {
        ".read": "auth != null && ((data.child('rider_id').val() === auth.uid) || (data.child('driver_id').val() === auth.uid) || (data.child('matched_driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))",
        ".write": false
      }
    },
    "active_deliveries": {
      "$deliveryId": {
        ".read": "auth != null && ((data.child('customer_id').val() === auth.uid) || (data.child('driver_id').val() === auth.uid) || (root.child('delivery_requests/' + $deliveryId + '/customer_id').val() === auth.uid) || (root.child('delivery_requests/' + $deliveryId + '/driver_id').val() === auth.uid))",
        ".write": false
      }
    },

    "ride_chats": {
      "$rideId": {
        ".read": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))",
        "messages": {
          ".indexOn": ["createdAt", "created_at", "timestamp"],
          "$messageId": {
            ".read": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))",
            ".write": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid)) && ((!newData.hasChild('senderId')) || (newData.child('senderId').val() === auth.uid)) && ((!newData.hasChild('sender_id')) || (newData.child('sender_id').val() === auth.uid))"
          }
        },
        "unread": {
          "$uid": {
            ".read": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))",
            ".write": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))"
          }
        }
      }
    },

    "calls": {
      ".indexOn": [
        "receiverId",
        "receiver_id",
        "callerId",
        "caller_id",
        "ride_id",
        "rideId",
        "createdAt",
        "updatedAt"
      ],
      "$rideId": {
        ".read": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid) || (data.exists() && ((data.child('callerId').val() === auth.uid) || (data.child('receiverId').val() === auth.uid) || (data.child('rider_id').val() === auth.uid) || (data.child('driver_id').val() === auth.uid))))",
        ".write": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))",
        "participants": {
          "$participantId": {
            ".read": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))",
            ".write": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))"
          }
        }
      }
    },

    "shared_trip_lookup": {
      "$rideId": {
        ".read": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid))",
        ".write": "auth != null && (root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid)"
      }
    },
    "shared_trips": {
      "$token": {
        ".read": "auth != null && root.child('shared_trip_lookup/' + data.child('ride_id').val() + '/token').val() === $token",
        ".write": "auth != null && root.child('ride_requests/' + newData.child('ride_id').val() + '/rider_id').val() === auth.uid"
      }
    },

    "trip_route_logs": {
      "$rideId": {
        ".read": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))",
        ".write": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/matched_driver_id').val() === auth.uid))"
      }
    },

    "dispatch_uploads": {
      "$rideId": {
        "$category": {
          "$fileId": {
            ".read": "auth != null && ((root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid))",
            ".write": "auth != null && ((newData.child('uploaded_by').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid))"
          }
        }
      }
    },

    "support_queue": {
      "$rideId": {
        ".read": "auth != null && ((root.child('users/' + auth.uid + '/role').val() === 'admin') || (root.child('users/' + auth.uid + '/role').val() === 'support') || (data.child('rider_id').val() === auth.uid) || (data.child('driver_id').val() === auth.uid))",
        ".write": "auth != null && ((root.child('users/' + auth.uid + '/role').val() === 'admin') || (root.child('users/' + auth.uid + '/role').val() === 'support') || (data.child('rider_id').val() === auth.uid) || (data.child('driver_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid))"
      }
    },
    "admin_rides": {
      "$rideId": {
        ".read": "auth != null && ((root.child('users/' + auth.uid + '/role').val() === 'admin') || (root.child('users/' + auth.uid + '/role').val() === 'support'))",
        ".write": "auth != null && ((root.child('users/' + auth.uid + '/role').val() === 'admin') || (root.child('users/' + auth.uid + '/role').val() === 'support') || (root.child('ride_requests/' + $rideId + '/rider_id').val() === auth.uid) || (root.child('ride_requests/' + $rideId + '/driver_id').val() === auth.uid))"
      }
    },

    "support_tickets": {
      ".indexOn": ["createdByUserId", "tripId", "status", "updatedAt"],
      "$ticketId": {
        ".read": "auth != null && ((data.child('createdByUserId').val() === auth.uid) || (root.child('users/' + auth.uid + '/role').val() === 'admin') || (root.child('users/' + auth.uid + '/role').val() === 'support'))",
        ".write": "auth != null && ((!data.exists() && newData.child('createdByUserId').val() === auth.uid) || (data.child('createdByUserId').val() === auth.uid) || (root.child('users/' + auth.uid + '/role').val() === 'admin') || (root.child('users/' + auth.uid + '/role').val() === 'support'))"
      }
    },
    "support_ticket_messages": {
      "$ticketId": {
        "$messageId": {
          ".read": "auth != null && ((root.child('support_tickets/' + $ticketId + '/createdByUserId').val() === auth.uid) || (root.child('users/' + auth.uid + '/role').val() === 'admin') || (root.child('users/' + auth.uid + '/role').val() === 'support'))",
          ".write": "auth != null && ((root.child('support_tickets/' + $ticketId + '/createdByUserId').val() === auth.uid) || (root.child('users/' + auth.uid + '/role').val() === 'admin') || (root.child('users/' + auth.uid + '/role').val() === 'support'))"
        }
      }
    }
  }
}
