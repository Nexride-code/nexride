rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function roleClaimMatches(roles) {
      return signedIn() && (
        request.auth.token.role in roles ||
        request.auth.token.supportRole in roles
      );
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.super_admin == true ||
        roleClaimMatches(['admin', 'super_admin'])
      );
    }

    function isSupportClaim() {
      return signedIn() && (
        request.auth.token.support == true ||
        request.auth.token.isSupport == true ||
        roleClaimMatches([
          'support',
          'support_agent',
          'support_manager',
          'admin',
          'super_admin',
        ])
      );
    }

    function isSupportDocument() {
      return signedIn() &&
        exists(/databases/$(database)/documents/support_staff/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/support_staff/$(request.auth.uid)).data.enabled != false &&
        get(/databases/$(database)/documents/support_staff/$(request.auth.uid)).data.role in [
          'support_agent',
          'support_manager',
          'admin',
          'super_admin',
        ];
    }

    function isSupport() {
      return isAdmin() || isSupportClaim() || isSupportDocument();
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Riders may only PATCH consent / selfie bookkeeping fields — never identity review workflow.
    function riderUserConsentCreateKeysOk() {
      return request.resource.data.keys().hasOnly([
        'termsAccepted',
        'termsAcceptedAt',
        'termsVersion',
        'ageConfirmed',
        'ageConfirmedAt',
      ]);
    }

    function riderRolloutBootstrapCreateOk() {
      return request.resource.data.keys().hasOnly([
        'rollout_region_id',
        'rollout_city_id',
        'rollout_dispatch_market_id',
      ]);
    }

    function riderUserConsentWriteKeysAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'termsAccepted',
        'termsAcceptedAt',
        'termsVersion',
        'ageConfirmed',
        'ageConfirmedAt',
        'selfieUploaded',
        'selfieUploadedAt',
        'rollout_region_id',
        'rollout_city_id',
        'rollout_dispatch_market_id',
      ]);
    }

    // Ensures admins can set verificationStatus / review metadata; riders cannot add, change,
    // or strip these keys on self-service writes.
    function riderUserPreservesAdminVerificationFields() {
      return (!('verificationStatus' in resource.data) ||
          resource.data.verificationStatus ==
            request.resource.data.verificationStatus) &&
        (!('verificationReviewedAt' in resource.data) ||
          resource.data.verificationReviewedAt ==
            request.resource.data.verificationReviewedAt) &&
        (!('verificationReviewedBy' in resource.data) ||
          resource.data.verificationReviewedBy ==
            request.resource.data.verificationReviewedBy) &&
        (!('verificationRejectionReason' in resource.data) ||
          resource.data.verificationRejectionReason ==
            request.resource.data.verificationRejectionReason) &&
        (!('verificationRejected' in resource.data) ||
          resource.data.verificationRejected ==
            request.resource.data.verificationRejected) &&
        (!('selfieReviewQueuedAt' in resource.data) ||
          resource.data.selfieReviewQueuedAt ==
            request.resource.data.selfieReviewQueuedAt);
    }

    function isTicketOwner() {
      return signedIn() && resource.data.createdByUserId == request.auth.uid;
    }

    /** Merchant portal: owner or listed staff (same uid as staff_uids array). */
    function merchantMemberCanReadMerchantDoc(merchantId) {
      return signedIn()
        && exists(/databases/$(database)/documents/merchants/$(merchantId))
        && (
          get(/databases/$(database)/documents/merchants/$(merchantId)).data.owner_uid
            == request.auth.uid
          || (
            'staff_uids' in get(/databases/$(database)/documents/merchants/$(merchantId)).data
            && request.auth.uid
              in get(/databases/$(database)/documents/merchants/$(merchantId)).data.staff_uids
          )
        );
    }

    function ticketOwnerById(ticketId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/support_tickets/$(ticketId)) &&
        get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.createdByUserId == request.auth.uid;
    }

    function ticketRoleById(ticketId) {
      return get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.createdByType;
    }

    function isValidUserTicketCreate() {
      return signedIn() &&
        request.resource.data.createdByUserId == request.auth.uid &&
        request.resource.data.createdByType in ['rider', 'driver'] &&
        request.resource.data.status == 'open' &&
        request.resource.data.assignedToStaffId == '' &&
        request.resource.data.assignedToStaffName == 'Unassigned' &&
        request.resource.data.escalated == false &&
        request.resource.data.resolution == '' &&
        request.resource.data.replyCount == 1 &&
        request.resource.data.internalNoteCount == 0 &&
        request.resource.data.lastPublicSenderRole == request.resource.data.createdByType &&
        request.resource.data.internalNotes.size() == 0 &&
        request.resource.data.staffSeenAt.size() == 0;
    }

    function isValidUserTicketUpdate() {
      return isTicketOwner() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'updatedAt',
          'lastReplyAt',
          'lastExternalReplyAt',
          'requesterSeenAt',
          'replyCount',
          'lastPublicSenderRole',
          'status',
          'resolvedAt',
          'closedAt',
        ]) &&
        request.resource.data.createdByUserId == resource.data.createdByUserId &&
        request.resource.data.createdByType == resource.data.createdByType &&
        request.resource.data.ticketId == resource.data.ticketId &&
        request.resource.data.subject == resource.data.subject &&
        request.resource.data.message == resource.data.message &&
        request.resource.data.category == resource.data.category &&
        request.resource.data.priority == resource.data.priority &&
        request.resource.data.tripId == resource.data.tripId &&
        request.resource.data.assignedToStaffId == resource.data.assignedToStaffId &&
        request.resource.data.assignedToStaffName == resource.data.assignedToStaffName &&
        request.resource.data.attachments == resource.data.attachments &&
        request.resource.data.internalNotes == resource.data.internalNotes &&
        request.resource.data.internalNoteCount == resource.data.internalNoteCount &&
        request.resource.data.escalated == resource.data.escalated &&
        request.resource.data.staffSeenAt == resource.data.staffSeenAt &&
        request.resource.data.firstResponseAt == resource.data.firstResponseAt &&
        request.resource.data.lastSupportReplyAt == resource.data.lastSupportReplyAt &&
        request.resource.data.resolution == resource.data.resolution &&
        request.resource.data.replyCount >= resource.data.replyCount &&
        request.resource.data.lastPublicSenderRole in ['rider', 'driver'] &&
        (
          request.resource.data.status == resource.data.status ||
          (
            resource.data.status in ['pending_user', 'resolved', 'closed'] &&
            request.resource.data.status == 'open'
          )
        );
    }

    function isValidUserMessageCreate(ticketId) {
      return ticketOwnerById(ticketId) &&
        request.resource.data.ticketDocumentId == ticketId &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.senderRole == ticketRoleById(ticketId) &&
        request.resource.data.visibility == 'public';
    }

    match /support_staff/{staffUid} {
      allow read: if isSupport();
      allow create, update: if isAdmin() || (isSupport() && request.auth.uid == staffUid);
      allow delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || isSupport() || isTicketOwner();
      allow create: if isAdmin() || isSupport() || isValidUserTicketCreate();
      allow update: if isAdmin() || isSupport() || isValidUserTicketUpdate();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || isSupport() ||
          (ticketOwnerById(ticketId) && resource.data.visibility != 'internal');
        allow create: if isAdmin() || isSupport() || isValidUserMessageCreate(ticketId);
        allow update, delete: if isAdmin() || isSupport();
      }
    }

    match /support_logs/{logId} {
      allow read, create: if isAdmin() || isSupport();
      allow update, delete: if isAdmin();
    }

    // Rollout delivery matrix + per-city bubbles. Writes via Cloud Functions only.
    match /delivery_regions/{regionId} {
      allow read: if signedIn();
      allow create, update, delete: if false;

      match /cities/{cityId} {
        allow read: if signedIn();
        allow create, update, delete: if false;
      }
    }

    // Reserved for server-owned fare tables (no client writes).
    match /region_pricing/{regionId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // Merchants — owners + staff may read; writes only via Cloud Functions.
    match /merchants/{merchantId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.owner_uid == request.auth.uid)
        || (signedIn()
          && 'staff_uids' in resource.data
          && request.auth.uid in resource.data.staff_uids);
      allow create, update, delete: if false;
    }

    // Merchant verification documents — server-side writes only; merchant/admin read.
    match /merchant_verification_documents/{merchantId}/documents/{documentType} {
      allow read: if isAdmin()
        || (
          signedIn()
          && exists(/databases/$(database)/documents/merchants/$(merchantId))
          && get(/databases/$(database)/documents/merchants/$(merchantId)).data.owner_uid
            == request.auth.uid
        );
      allow create, update, delete: if false;
    }

    match /merchant_verification_documents/{merchantId} {
      allow read, write: if false;
    }

    // Rider profile compliance (Firestore) — field-level rider restrictions
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin() || isSupport();

      allow create: if isOwner(uid)
        && (riderUserConsentCreateKeysOk() || riderRolloutBootstrapCreateOk());

      allow update: if isAdmin()
        || (
          isOwner(uid)
          && riderUserConsentWriteKeysAllowed()
          && riderUserPreservesAdminVerificationFields()
        );

      allow delete: if isAdmin();
    }

    // Shared trip lookup tokens — tighten write if abused (currently any signed-in user may write).
    match /shared_trips/{token} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /merchant_orders/{orderId} {
      allow read: if signedIn()
        && resource.data.merchant_id is string
        && merchantMemberCanReadMerchantDoc(resource.data.merchant_id);
      allow write: if false;
    }

    match /merchants/{merchantId}/menu_categories/{docId} {
      allow read, write: if false;
    }

    match /merchants/{merchantId}/menu_items/{docId} {
      allow read, write: if false;
    }

    match /merchants/{merchantId}/internal_notes/{docId} {
      allow read, write: if false;
    }

    // Rider identity verification submissions — rider writes own record; admin reads/manages.
    match /identity_verifications/{uid} {
      allow read: if isOwner(uid) || isAdmin() || isSupport();
      // Riders submit their own record; review fields must remain null/empty.
      allow create, update: if isOwner(uid)
        && request.resource.data.user_type == 'rider'
        && request.resource.data.uid == uid
        && request.resource.data.get('reviewed_at', null) == null
        && request.resource.data.get('review_note', '') == '';
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
