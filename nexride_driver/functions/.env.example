# Copy to `.env` for local emulators (`firebase emulators:start --only functions`).
# Do not commit `.env`.

FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
NEXRIDE_PLATFORM_FEE_NGN=30
NEXRIDE_SMALL_ORDER_FEE_NGN=15
NEXRIDE_SMALL_ORDER_THRESHOLD_NGN=3000

# Callable getRideCallRtcToken (omit to return agora_not_configured)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Optional: merchant approval emails (https://resend.com). Push still sends without these.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
