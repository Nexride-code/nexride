rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.admin == true;
    }

    function isImageUploadMax10MiB() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }

    function isMerchantVerificationUpload() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size < 12 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    function isMerchantOwnerUpload(merchantId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/merchants/$(merchantId))
        && request.auth.uid
          == firestore.get(/databases/(default)/documents/merchants/$(merchantId)).data.owner_uid;
    }

    function isMerchantStaffUpload(merchantId) {
      let m = firestore.get(/databases/(default)/documents/merchants/$(merchantId)).data;
      return signedIn()
        && firestore.exists(/databases/(default)/documents/merchants/$(merchantId))
        && ('staff_uids' in m)
        && m.staff_uids is list
        && request.auth.uid in m.staff_uids;
    }

    function merchantUploadAllowed(merchantId) {
      return isMerchantOwnerUpload(merchantId) || isMerchantStaffUpload(merchantId);
    }

    match /user_verification/{uid}/{allPaths=**} {
      // Rider uploads own selfies only — no public read (admin/console uses privileged access).
      allow read: if isAdmin();

      // create/update need metadata; deletes have no request.resource — keep separate from rider image checks.
      allow create, update: if isOwner(uid)
        && request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;

      // Preserve audit trail: only admins remove blobs (riders can replace via upload to same object path).
      allow delete: if isAdmin();
    }

    // Rider identity verification uploads (selfie). App uploads here; admin reviews.
    match /rider_verification_uploads/{uid}/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid)
        && request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    match /ride_chats/{rideId}/{senderUid}/{fileName} {
      allow write: if signedIn() && request.auth.uid == senderUid && isImageUploadMax10MiB();
      allow read: if signedIn();
    }

    match /ride_payment_proofs/{rideId}/{uid}/{fileName} {
      allow write: if signedIn() && request.auth.uid == uid && isImageUploadMax10MiB();
      allow read: if signedIn();
    }

    match /dispatch_uploads/{rideId}/{category}/{fileName} {
      allow write: if signedIn() && isImageUploadMax10MiB();
      allow read: if signedIn();
    }

    match /driver_documents/{uid}/{fileName} {
      allow write: if signedIn()
        && request.auth.uid == uid
        && isImageUploadMax10MiB();
      allow read: if signedIn();
    }

    match /driver_verification_uploads/{uid}/{allPaths=**} {
      allow write: if isOwner(uid)
        && request.resource != null
        && request.resource.size > 0
        && request.resource.size < 12 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
      allow read: if isOwner(uid) || isAdmin();
    }

    // Bank transfer receipts: rider uploads under their uid.
    match /receipts/{uid}/{rideId}/{fileName} {
      allow write: if signedIn()
        && request.auth.uid == uid
        && fileName == 'bank_transfer_receipt.jpg'
        && isImageUploadMax10MiB();
      allow read: if signedIn()
        && (request.auth.uid == uid || isAdmin());
    }

    // Merchant verification uploads — owner writes; admins read (callables use admin SDK too).
    match /merchant_uploads/{merchantId}/menu/categories/{categoryId}/{fileName} {
      allow read: if isAdmin() || merchantUploadAllowed(merchantId);
      allow create, update: if merchantUploadAllowed(merchantId) && isImageUploadMax10MiB();
      allow delete: if isAdmin() || merchantUploadAllowed(merchantId);
    }

    match /merchant_uploads/{merchantId}/menu/items/{itemId}/{fileName} {
      allow read: if isAdmin() || merchantUploadAllowed(merchantId);
      allow create, update: if merchantUploadAllowed(merchantId) && isImageUploadMax10MiB();
      allow delete: if isAdmin() || merchantUploadAllowed(merchantId);
    }

    match /merchant_uploads/{merchantId}/profile/logo/{fileName} {
      allow read: if isAdmin() || merchantUploadAllowed(merchantId);
      allow create, update: if merchantUploadAllowed(merchantId) && isImageUploadMax10MiB();
      allow delete: if isAdmin() || merchantUploadAllowed(merchantId);
    }

    match /merchant_uploads/{merchantId}/profile/banner/{fileName} {
      allow read: if isAdmin() || merchantUploadAllowed(merchantId);
      allow create, update: if merchantUploadAllowed(merchantId) && isImageUploadMax10MiB();
      allow delete: if isAdmin() || merchantUploadAllowed(merchantId);
    }

    match /merchant_uploads/{merchantId}/profile/{fileName} {
      allow read: if isAdmin() || merchantUploadAllowed(merchantId);
      allow create, update: if merchantUploadAllowed(merchantId) && isImageUploadMax10MiB();
      allow delete: if isAdmin() || merchantUploadAllowed(merchantId);
    }

    match /merchant_uploads/{merchantId}/menu/{itemId}/{fileName} {
      allow read: if isAdmin() || merchantUploadAllowed(merchantId);
      allow create, update: if merchantUploadAllowed(merchantId) && isImageUploadMax10MiB();
      allow delete: if isAdmin() || merchantUploadAllowed(merchantId);
    }

    match /merchant_uploads/{merchantId}/verification/{documentType}/{fileName} {
      allow read: if isAdmin() || merchantUploadAllowed(merchantId);
      allow create, update: if merchantUploadAllowed(merchantId)
        && documentType in [
          'cac_document',
          'owner_id',
          'storefront_photo',
          'address_proof',
          'operating_license',
        ]
        && isMerchantVerificationUpload();
      allow delete: if isAdmin();
    }

    // Merchant wallet manual top-up payment proofs (callable validates path + object exists).
    match /merchant_uploads/{merchantId}/wallet_topups/{requestId}/{fileName} {
      allow read: if isAdmin() || merchantUploadAllowed(merchantId);
      allow create, update: if merchantUploadAllowed(merchantId) && isMerchantVerificationUpload();
      allow delete: if isAdmin();
    }
  }
}
